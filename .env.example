# Read-only Maroma API credentials (server-side only)
MAROMA_API_BASE_URL=https://staging-api.example.com
MAROMA_CONSUMER_KEY=replace_with_readonly_consumer_key
MAROMA_CONSUMER_SECRET=replace_with_readonly_consumer_secret

# Extra safety: always block production domains.
# Comma-separated hostnames (no protocol).
MAROMA_BLOCKED_HOSTS=maroma.com,www.maroma.com,api.maroma.com

# Allowlist for outbound API hosts.
# If empty, MAROMA_API_BASE_URL host is used.
MAROMA_ALLOWED_HOSTS=staging-api.example.com
